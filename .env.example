# Archivo de variables de entorno para Hermes Agent Docker
# Copia este archivo a .env y configura tus valores

# API Keys (opcional - ya están en ~/.hermes/.env)
# Descomenta si prefieres pasarlas por variable de entorno en lugar del archivo
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Configuración de red
# HERMES_PORT=8642

# Opciones avanzadas
# HERMES_SKIP_CONFIG_MIGRATION=1
